# Defaults match `./scripts/serve_qwen.sh` running on this machine.
QWEN_BASE_URL=http://127.0.0.1:8000/v1
QWEN_API_KEY=EMPTY
QWEN_MODEL=qwen3.6-27b
QWEN_TIMEOUT=120
# vLLM rejects max_tokens > max_model_len with VLLMValidationError, so this
# stays under QWEN_SERVER_MAX_LEN. 1024 leaves 1024 prompt tokens of room.
QWEN_MAX_TOKENS=1024
# Mirror of the serve script's --max-model-len. The client clamps every
# chat request's max_tokens against this minus the prompt token estimate
# minus 64 tokens of chat-template headroom. Raise this if you raised
# QWEN_SERVE_MAX_LEN on the server.
QWEN_SERVER_MAX_LEN=2048
LOOP_INTERVAL_SECONDS=45
LOOP_MAX_FILE_BYTES=60000
LOOP_PUSH=1
